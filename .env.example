# OpenAI API Key
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

OPENAI_MODEL=gpt-5.4

# LeetCode Session ID
# 1. Log in to leetcode.com
# 2. Open DevTools (F12) → Application → Cookies → leetcode.com
# 3. Copy the value of "LEETCODE_SESSION"
LEETCODE_SESSION=your_leetcode_session_here
# LeetCode CSRF Token
# 1. Same as above: DevTools → Application → Cookies → leetcode.com
# 2. Copy the value of "csrftoken"
LEETCODE_CSRFTOKEN=your_leetcode_csrf_here